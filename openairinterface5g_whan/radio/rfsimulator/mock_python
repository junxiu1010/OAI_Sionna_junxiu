def _env_int(name: str, default: int) -> int:
    v = os.getenv(name)
    if v is None:
        return default
    try:
        return int(v)
    except ValueError:
        return default


def parse_args(argv=None):
    p = argparse.ArgumentParser(description="OAI ↔ Sionna bi‑directional IQ proxy")
    p.add_argument("--ue-host", default=os.getenv("SIONNA_CH_UE_HOST", "0.0.0.0"))
    p.add_argument("--ue-port", type=int, default=_env_int("SIONNA_CH_UE_PORT", 6018))
    p.add_argument("--gnb-host", default=os.getenv("SIONNA_CH_GNB_HOST", "0.0.0.0"))
    p.add_argument("--gnb-port", type=int, default=_env_int("SIONNA_CH_GNB_PORT", 6017))
    p.add_argument("--max-ues", type=int, default=_env_int("SIONNA_CH_MAX_UES", 250))
    p.add_argument("--big-endian", action="store_true", help="interpret headers big‑endian")
    p.add_argument("--no-handshake", action="store_true")
    p.add_argument("--handshake-ts", type=int, default=_env_int("SIONNA_CH_HANDSHAKE_TS", 0),
                   help="explicit handshake timestamp (0=auto)")
    p.add_argument("--delay-ms", type=float, default=float(os.getenv("SIONNA_CH_DELAY_MS", 0.0)))
    p.add_argument("--drop-pct", type=float, default=float(os.getenv("SIONNA_CH_DROP_PCT", 0.0)))
    p.add_argument("--log", choices=LOG_LEVELS.keys(), default=os.getenv("SIONNA_CH_LOG", "info"))
    p.add_argument("--strict-oai", action="store_true", help="error on malformed header")
    p.add_argument("--self-test", action="store_true", help="내부 루프백으로 6017/6018 송수신 검증 후 종료")
    args = p.parse_args(argv)
    if args.handshake_ts == 0:
        args.handshake_ts = None
    return args

###############################################################################
# 메인
###############################################################################

def main(argv=None):
    args = parse_args(argv)
    if args.self_test:
        _self_test(args.ue_host, args.ue_port, args.gnb_host, args.gnb_port, big_endian=args.big_endian)
        return
    srv = ProxyServer(
        ue_host=args.ue_host,
        ue_port=args.ue_port,
        gnb_host=args.gnb_host,
        gnb_port=args.gnb_port,
        max_ues=args.max_ues,
        big_endian=args.big_endian,
        do_handshake=not args.no_handshake,
        handshake_ts=args.handshake_ts,
        delay_ms=args.delay_ms,
        drop_pct=args.drop_pct,
        log_level=args.log,
        strict_oai=args.strict_oai,
    )
    srv.run()


if __name__ == "__main__":  # pragma: no cover
    main()

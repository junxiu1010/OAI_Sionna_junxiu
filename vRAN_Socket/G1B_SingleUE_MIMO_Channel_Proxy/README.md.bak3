# v3 SISO bypass
sudo bash launch_all.sh -v v3 -m gpu-ipc -b

# v3 비대칭 (gNB 2x1)
sudo bash launch_all.sh -v v3 -m gpu-ipc -b -ga 2 1

# v3 대칭 (gNB 2x1, UE 2x1)

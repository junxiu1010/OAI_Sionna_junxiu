```bash
cd /home/dclcom57/oai_sionna_junxiu/vRAN_Socket/G1B_MultiUE_MIMO_Channel_Proxy

# Test 1: v7 SISO bypass (regression)
sudo bash launch_all.sh -v v7 -m gpu-ipc -b


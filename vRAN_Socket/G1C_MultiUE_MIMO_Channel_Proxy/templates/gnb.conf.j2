{#- gnb.conf Jinja2 template – generated by Core Emulator from master_config.yaml -#}
{#- Antenna derived values are injected by the template engine:                   -#}
{#-   gnb_ant     = gnb.nx * gnb.ny * pol_mult                                   -#}
{#-   ue_ant      = ue.nx  * ue.ny  * pol_mult                                   -#}
{#-   pol_mult    = 2 if polarization=="dual" else 1                              -#}
{#-   gnb_spatial = gnb.nx * gnb.ny                                               -#}
{#-   xp          = pol_mult                                                      -#}
{#-   n1          = gnb_spatial if xp==2 else gnb_ant                             -#}
{%- set br = bearer | default({}) -%}
Active_gNBs = ( "gNB-OAI");
# Asn1_verbosity, choice in: none, info, annoying
Asn1_verbosity = "none";

gNBs =
(
 {
    ////////// Identification parameters:
    gNB_ID    =  0xe00;
    gNB_name  =  "gNB-OAI";

    // Tracking area code, 0x0000 and 0xfffe are reserved values
    tracking_area_code  =  1;
    plmn_list = ({ mcc = 001; mnc = 01; mnc_length = 2; snssaiList = ({ sst = 1; }) });

    nr_cellid = 12345678L;

    ////////// Physical parameters:

    pdsch_AntennaPorts_N1                                     = {{ n1 }};
    pdsch_AntennaPorts_N2                                     = 1;
    pdsch_AntennaPorts_XP                                     = {{ xp }};
    pusch_AntennaPorts                                        = {{ ue_ant }};
    do_CSIRS                                                  = 1;
    do_SRS                                                    = 1;
    do_SINR                                                   = 1;
    do_deltaMCS                                               = 1;
    uess_agg_levels = [0,8,4,0,0]
    servingCellConfigCommon = (
    {

      physCellId                                                    = 0;

      absoluteFrequencySSB                                             = 641280;
      dl_frequencyBand                                                 = {{ carrier.band }};
      dl_absoluteFrequencyPointA                                       = 640008;
        dl_offstToCarrier                                              = 0;
        dl_subcarrierSpacing                                           = {{ scs_idx }};
        dl_carrierBandwidth                                            = {{ carrier.bandwidth_prb }};
        initialDLBWPlocationAndBandwidth                               = 28875;
        initialDLBWPsubcarrierSpacing                                   = {{ scs_idx }};
        initialDLBWPcontrolResourceSetZero                              = 12;
        initialDLBWPsearchSpaceZero                                     = 0;

      ul_frequencyBand                                              = {{ carrier.band }};
      ul_offstToCarrier                                             = 0;
      ul_subcarrierSpacing                                          = {{ scs_idx }};
      ul_carrierBandwidth                                           = {{ carrier.bandwidth_prb }};
      pMax                                                          = 20;
        initialULBWPlocationAndBandwidth                            = 28875;
        initialULBWPsubcarrierSpacing                               = {{ scs_idx }};

        prach_ConfigurationIndex                                  = 98;
          prach_msg1_FDM                                            = 0;
          prach_msg1_FrequencyStart                                 = 0;
          zeroCorrelationZoneConfig                                 = 13;
          preambleReceivedTargetPower                               = -96;
          preambleTransMax                                          = 8;
        powerRampingStep                                            = 1;
        ra_ResponseWindow                                           = 5;
        ssb_perRACH_OccasionAndCB_PreamblesPerSSB_PR                = 4;
        ssb_perRACH_OccasionAndCB_PreamblesPerSSB                   = 14;
        ra_ContentionResolutionTimer                                = 7;
        rsrp_ThresholdSSB                                           = 19;
        prach_RootSequenceIndex_PR                                  = 2;
        prach_RootSequenceIndex                                     = 1;
        msg1_SubcarrierSpacing                                      = {{ scs_idx }},
        restrictedSetConfig                                         = 0,

        msg3_DeltaPreamble                                          = 1;
        p0_NominalWithGrant                                         =-70;

        pucchGroupHopping                                           = 0;
        hoppingId                                                   = 40;
        p0_nominal                                                  = -70;

      ssb_PositionsInBurst_Bitmap                                   = 1;
      ssb_periodicityServingCell                                    = 2;
      dmrs_TypeA_Position                                           = 0;
      subcarrierSpacing                                             = {{ scs_idx }};

      referenceSubcarrierSpacing                                    = {{ scs_idx }};
      dl_UL_TransmissionPeriodicity                                 = 6;
      nrofDownlinkSlots                                             = 7;
      nrofDownlinkSymbols                                           = 6;
      nrofUplinkSlots                                               = 2;
      nrofUplinkSymbols                                             = 4;

      ssPBCH_BlockPower                                             = 0;
  }

  );


    // CSI-RS/SRS/PMI configuration (generated from master_config.yaml)
    csirs_detailed_config = (
    {
        periodicity = {{ csi_rs.periodicity }};
        first_symbol = {{ csi_rs.first_symbol }};
        power_offset = {{ csi_rs.power_offset }};
        density = {{ csi_rs.density }};
        freq_start_rb = {{ csi_rs.freq_start_rb }};
        freq_nrof_rbs = {{ csi_rs.freq_nrof_rbs }};
        freq_allocation = [{{ csi_rs.freq_allocation | join(', ') }}];
        cdm_type = "{{ csi_rs.cdm_type }}";
        nrof_ports = {{ csi_rs.nrof_ports }};
        qcl_info = {{ csi_rs.qcl_info }};
    }
    );

    srs_detailed_config = (
    {
        periodicity = {{ srs.periodicity }};
        start_position = {{ srs.start_position }};
        num_symbols = {{ srs.num_symbols }};
        repetition_factor = {{ srs.repetition_factor }};
        comb_offset = {{ srs.comb_offset }};
        cyclic_shift = {{ srs.cyclic_shift }};
        freq_domain_position = {{ srs.freq_domain_position }};
        freq_domain_shift = {{ srs.freq_domain_shift }};
        freq_hopping_b_srs = {{ srs.freq_hopping_b_srs }};
        freq_hopping_b_hop = {{ srs.freq_hopping_b_hop }};
        freq_hopping_c_srs = {{ srs.freq_hopping_c_srs }};
        group_hopping = "{{ srs.group_hopping }}";
        alpha = "{{ srs.alpha }}";
        p0 = {{ srs.p0 }};
        nrof_srs_ports = {{ srs.nrof_srs_ports }};
    }
    );

    codebook_detailed_config = (
    {
{% if codebook.type == "type1" %}
        codebook_type = "type1";
        sub_type = "{{ codebook.sub_type }}";
        mode = {{ codebook.mode }};
        pmi_restriction = {{ "0x%02x" | format(codebook.pmi_restriction) if codebook.pmi_restriction is number else codebook.pmi_restriction }};
        ri_restriction = {{ "0x%02x" | format(codebook.ri_restriction) if codebook.ri_restriction is number else codebook.ri_restriction }};
        n1_n2_config = "{{ codebook.n1_n2_config }}";
{% elif codebook.type == "type2" %}
        codebook_type = "type2";
        sub_type = "{{ codebook.sub_type }}";
        mode = {{ codebook.mode }};
        pmi_restriction = {{ "0x%02x" | format(codebook.pmi_restriction) if codebook.pmi_restriction is number else codebook.pmi_restriction }};
        ri_restriction = {{ "0x%02x" | format(codebook.ri_restriction) if codebook.ri_restriction is number else codebook.ri_restriction }};
        n1_n2_config = "{{ codebook.n1_n2_config }}";
        phase_alphabet_size = "{{ codebook.phase_alphabet_size }}";
        subband_amplitude = {{ codebook.subband_amplitude }};
        number_of_beams = {{ codebook.number_of_beams }};
        port_selection_sampling_size = {{ codebook.port_selection_sampling_size }};
{% endif %}
    }
    );

    csi_measurement_config = (
    {
        cqi_table = "{{ csi_measurement.cqi_table }}";
        ri_table = "{{ csi_measurement.ri_table }}";
        pmi_table = "{{ csi_measurement.pmi_table }}";
        report_periodicity = {{ csi_measurement.report_periodicity }};
        report_offset = {{ csi_measurement.report_offset }};
        cqi_threshold = {{ csi_measurement.cqi_threshold }};
        ri_threshold = {{ csi_measurement.ri_threshold }};
        enable_rsrp = {{ csi_measurement.enable_rsrp }};
        enable_ri = {{ csi_measurement.enable_ri }};
        enable_pmi = {{ csi_measurement.enable_pmi }};
        enable_cqi = {{ csi_measurement.enable_cqi }};
        enable_sinr = {{ csi_measurement.enable_sinr }};
    }
    );

    # ------- SCTP definitions
    SCTP :
    {
        SCTP_INSTREAMS  = 2;
        SCTP_OUTSTREAMS = 2;
    };


    ////////// AMF parameters:
    amf_ip_address = ({ ipv4 = "{{ network.amf_ip }}"; });


    NETWORK_INTERFACES :
    {
        GNB_IPV4_ADDRESS_FOR_NG_AMF              = "{{ network.gnb_ip }}/{{ network.gnb_ip_prefix }}";
        GNB_IPV4_ADDRESS_FOR_NGU                 = "{{ network.gnb_ip }}/{{ network.gnb_ip_prefix }}";
        GNB_PORT_FOR_S1U                         = {{ network.get('gtpu_port', 2152) if network is mapping else 2152 }};
    };

    enable_sdap = {{ 1 if br.get('enable_sdap', false) else 0 }};
    drbs        = {{ br.get('drbs', 1) }};
    um_on_default_drb = {{ 1 if br.get('um_on_default_drb', false) else 0 }};

  }
);

MACRLCs = (
{
  num_cc                      = 1;
  tr_s_preference             = "local_L1";
  tr_n_preference             = "local_RRC";
  pusch_TargetSNRx10          = 150;
  pucch_TargetSNRx10          = 200;
  ul_harq_round_max           = 8;
  dl_harq_round_max           = 8;
  pucch_FailureThres          = 1000;
  pusch_FailureThres          = 1000;
  mu_mimo                     = {{ 1 if system.mu_mimo | default(true) else 0 }};
  force_mu_dl_traffic         = {{ 1 if system.force_mu_dl_traffic | default(false) else 0 }};
}
);

L1s = (
{
  num_cc = 1;
  tr_n_preference       = "local_mac";
  prach_dtx_threshold   = 10;
  pucch0_dtx_threshold  = 0;
  pusch_dtx_threshold   = -10;
  tx_amp_backoff_dB     = 12;
  ofdm_offset_divisor   = 4294967295;
}
);

RUs = (
{
  local_rf       = "yes";
  nb_tx          = {{ gnb_ant }};
  nb_rx          = {{ ue_ant }};
  att_tx         = 12;
  att_rx         = 12;
  bands          = [{{ carrier.band }}];
  max_pdschReferenceSignalPower = -27;
  max_rxgain                    = 114;
  eNB_instances  = [0];
  clock_src = "internal";
}
);

channelmod = {
  max_chan=10;
  modellist="modellist_rfsimu_1";
  modellist_rfsimu_1 = (
    {
      model_name     = "rfsimu_channel_enB0"
      type           = "TDL_A";
      noise_power_dB = -100;
      DT=1e-7;
      FF=1.0;
      CO="low";
      CL=4;
      PL=1.0;
      NP=5;
    },
    {
      model_name     = "rfsimu_channel_ue0"
      type           = "TDL_A";
      noise_power_dB = -100;
      DT=1e-7;
      FF=1.0;
      CO="low";
      CL=4;
      PL=1.0;
      NP=5;
    },
    {
      model_name     = "rfsimu_channel_ue1"
      type           = "TDL_A";
      noise_power_dB = -100;
      DT=1e-7;
      FF=3.0;
      CO="low";
      CL=6;
      PL=1.0;
      NP=5;
    }
  );
};
rfsimulator :
{
  serveraddr = "server";
  serverport = 4043;
  options = ();
  modelname = "AWGN";
  IQfile = "/tmp/rfsimulator.iqs";
};

security = {
  ciphering_algorithms = ( "nea0" );
  integrity_algorithms = ( "nia2", "nia0" );
  drb_ciphering = "{{ 'yes' if br.get('drb_ciphering', true) else 'no' }}";
  drb_integrity = "{{ 'yes' if br.get('drb_integrity', false) else 'no' }}";
};

log_config :
{
  global_log_level                      ="info";
  hw_log_level                          ="info";
  phy_log_level                         ="info";
  mac_log_level                         ="info";
  rlc_log_level                         ="info";
  pdcp_log_level                        ="info";
  rrc_log_level                         ="info";
  ngap_log_level                        ="debug";
  f1ap_log_level                        ="debug";
};

e2_agent = {
  near_ric_ip_addr = "127.0.0.1";
  sm_dir = "/usr/local/lib/flexric/"
};

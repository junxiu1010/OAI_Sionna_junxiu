{#- Only the SMF local_subscription_infos QoS profile is parameterized. -#}
{#- All other sections are kept identical to the original. -#}
{%- set q = qos | default({}) -%}
{%- set fiveqi = q.get('default_5qi', 9) -%}
{%- set ambr_ul = q.get('session_ambr_ul', '10Gbps') -%}
{%- set ambr_dl = q.get('session_ambr_dl', '10Gbps') -%}
